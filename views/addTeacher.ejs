<%- include('partials/header') %>
<% title = "Add Teacher"; %>
<div class="container py-4">
  <div class="row">
    <div class="col-12 col-md-8 offset-md-2">
    <div class="card">
      <div class="card-header">
        <h3>Add Teacher</h3>
      </div>
      <div class="card-body">
        <form action="/teachers/add" method="POST">
          <div class="mb-3">
            <label>Name</label>
            <input name="name" class="form-control" required />
          </div>
          <div class="mb-3">
            <label>TSC Number</label>
            <input name="tsc_no" class="form-control" />
          </div>
          <div class="mb-3">
            <label>Grade</label>
            <input name="grade" class="form-control" />
          </div>
          <div class="mb-3">
            <label>Subject Combination</label>
            <input name="subject_combination" class="form-control" />
          </div>
          <div class="mb-3">
            <label>Department</label>
            <input name="department" class="form-control" />
          </div>
          <div class="mb-3">
            <label>Responsibility</label>
            <input name="responsibility" class="form-control" />
          </div>
          <div class="d-flex gap-2 form-actions border-top pt-3">
            <a href="/teachers" class="btn btn-secondary">Cancel</a>
            <button class="btn btn-primary">Add Teacher</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
