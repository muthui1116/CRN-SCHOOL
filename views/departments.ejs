<% title = "Departments"; %>
<div class="row">
  <div class="col-12 col-sm-12">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
          <h3 class="mb-1">Departments</h3>
          <p class="mb-0 text-muted">Manage academic departments and assign heads of department from a clean, responsive interface.</p>
        </div>
        <div class="d-flex gap-2 flex-wrap align-items-center">
          <a href="/departments" class="btn btn-sm btn-outline-secondary">Refresh</a>
          <a href="/departments/add" class="btn btn-sm btn-primary">Add Department</a>
        </div>
      </div>
      <div class="card-body">
        <div class="table-responsive rounded-3 shadow-sm">
          <table class="table table-striped table-hover table-sm align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>ID</th>
                <th>Name</th>
                <th>HOD</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (!(departments||[]).length) { %>
                <tr>
                  <td colspan="4" class="text-center text-muted py-4">No departments found. Add a department to get started.</td>
                </tr>
              <% } else { %>
                <% (departments||[]).forEach(d => { %>
                  <tr>
                    <td><%= d.id %></td>
                    <td><%= d.name %></td>
                    <td><%= d.hod || 'N/A' %></td>
                    <td class="table-actions">
                      <div class="d-flex gap-1 flex-wrap">
                        <a href="/departments/<%= d.id %>/edit" class="btn btn-sm btn-warning">Edit</a>
                        <form action="/departments/delete/<%= d.id %>" method="POST" class="m-0">
                          <button class="btn btn-sm btn-danger" onclick="return confirm('Delete this department?')">Delete</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
