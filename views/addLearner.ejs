<%- include('partials/header') %>
<% title = "Add Learner"; %>
<div class="container py-4">
  <div class="row">
    <div class="col-12 col-md-8 offset-md-2">
      <div class="card">
        <div class="card-header">
          <h3>Add Learner</h3>
        </div>
        <div class="card-body">
          <form action="/learners/add" method="POST">
            <div class="mb-3">
              <label>Name</label>
              <input name="name" class="form-control" required />
            </div>
            <div class="mb-3">
              <label>Assessment Number</label>
              <input name="assessment_number" class="form-control" />
            </div>
            <div class="mb-3">
              <label>ADN No</label>
              <input name="adn_no" class="form-control" />
            </div>
            <div class="mb-3">
              <label>Birth Certificate</label>
              <input name="birth_certificate" class="form-control" />
            </div>
            <div class="mb-3">
              <label>Grade</label>
              <select name="grade" class="form-select">
                <option value="">Select a grade</option>
                <% (grades||[]).forEach(g => { %>
                  <option value="<%= g.name %>"><%= g.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="mb-3">
              <label>Class Teacher</label>
              <select name="class_teacher" class="form-select">
                <option value="">Select a teacher</option>
                <% (teachers||[]).forEach(t => { %>
                  <option value="<%= t.name %>"><%= t.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="mb-3">
              <label>Responsibility</label>
              <input name="responsibility" class="form-control" />
            </div>
            <div class="d-flex gap-2 form-actions border-top pt-3">
              <a href="/learners" class="btn btn-secondary">Cancel</a>
              <button class="btn btn-primary">Add Learner</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
