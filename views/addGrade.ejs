<%- include('partials/header') %>
<% title = "Add Grade"; %>
<div class="container py-4">
  <div class="row">
    <div class="col-12 col-md-8 offset-md-2">
      <div class="card">
        <div class="card-header">
          <h3>Add Grade</h3>
        </div>
        <div class="card-body">
          <form action="/grades/add" method="POST">
            <div class="mb-3">
              <label>Grade Name</label>
              <input name="name" class="form-control" required />
            </div>
            <div class="mb-3">
              <label>Enrolment</label>
              <input name="enrolment" type="number" class="form-control" />
            </div>
            <div class="mb-3">
              <label>Class Teacher</label>
              <select name="class_teacher" class="form-select">
                <option value="">Select a teacher</option>
                <% (teachers||[]).forEach(t => { %>
                  <option value="<%= t.name %>"><%= t.name %></option>
                <% }) %>
              </select>
            </div>
            <button class="btn btn-primary">Add Grade</button>
            <a href="/grades" class="btn btn-secondary ms-2">Cancel</a>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
