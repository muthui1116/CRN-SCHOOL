<%- include('partials/header') %>

<div class="container-fluid">
  <div class="row g-0">

    <!-- Sidebar (full-width on xs, auto on md+) -->
    <aside class="col-12 col-md-auto p-0 bg-white border-bottom border-md-end sidebar">

      <div class="px-3 py-3 border-bottom">
        <h6 class="fw-semibold mb-0 text-dark">School Admin</h6>
        <small class="text-muted">Administration Panel</small>
      </div>

      <div class="px-3 pt-3 pb-1">
        <span class="text-uppercase text-muted fw-semibold" style="font-size: 10px; letter-spacing: .08em;">Management</span>
      </div>

      <div class="d-md-none px-3 pb-3">
        <label class="form-label visually-hidden" for="adminNavSelect">Admin navigation</label>
        <select id="adminNavSelect" class="form-select form-select-sm" onchange="if (this.value) window.location.href = this.value;">
          <option value="/admin" <%= page === 'users' ? 'selected' : '' %>>Users</option>
          <option value="/grades" <%= page === 'grades' ? 'selected' : '' %>>Grades</option>
          <option value="/teachers" <%= page === 'teachers' ? 'selected' : '' %>>Teachers</option>
          <option value="/departments" <%= page === 'departments' ? 'selected' : '' %>>Departments</option>
          <option value="/subjects" <%= page === 'subjects' ? 'selected' : '' %>>Learning Areas</option>
          <option value="/learners" <%= page === 'learners' ? 'selected' : '' %>>Learners</option>
        </select>
      </div>

      <a href="/admin" class="d-none d-md-flex align-items-center gap-2 px-3 py-2 text-decoration-none sidebar-link <%= page === 'users' ? 'active' : '' %>">
        <i class="fas fa-users fa-sm text-secondary"></i>
        <span>Users</span>
      </a>

      <a href="/grades" class="d-none d-md-flex align-items-center gap-2 px-3 py-2 text-decoration-none sidebar-link <%= page === 'grades' ? 'active' : '' %>">
        <i class="fas fa-book fa-sm text-secondary"></i>
        <span>Grades</span>
      </a>

      <a href="/teachers" class="d-none d-md-flex align-items-center gap-2 px-3 py-2 text-decoration-none sidebar-link <%= page === 'teachers' ? 'active' : '' %>">
        <i class="fas fa-user-tie me-1 text-secondary"></i>
        <span>Teachers</span>
      </a>

      <a href="/departments" class="d-none d-md-flex align-items-center gap-2 px-3 py-2 text-decoration-none sidebar-link <%= page === 'departments' ? 'active' : '' %>">
        <i class="fas fa-building fa-sm text-secondary"></i>
        <span>Departments</span>
      </a>

      <a href="/subjects" class="d-none d-md-flex align-items-center gap-2 px-3 py-2 text-decoration-none sidebar-link <%= page === 'subjects' ? 'active' : '' %>">
        <i class="fas fa-book-open fa-sm text-secondary"></i>
        <span>Learning Areas</span>
      </a>

      <a href="/learners" class="d-none d-md-flex align-items-center gap-2 px-3 py-2 text-decoration-none sidebar-link <%= page === 'learners' ? 'active' : '' %>">
        <i class="fas fa-graduation-cap fa-sm text-secondary"></i>
        <span>Learners</span>
      </a>

    </aside>

    <!-- Main content -->
    <main class="col bg-light overflow-auto main-content p-3">

      <% if (page === 'users') { %>
        <%- include('users.ejs') %>
      <% } else if (page === 'grades') { %>
        <%- include('grades.ejs') %>
      <% } else if (page === 'teachers') { %>
        <%- include('teachers.ejs') %>
      <% } else if (page === 'departments') { %>
        <%- include('departments.ejs') %>
      <% } else if (page === 'subjects') { %>
        <%- include('subjects.ejs') %>
      <% } else if (page === 'learners') { %>
        <%- include('learners.ejs') %>
      <% } %>

    </main>

  </div>
</div>

<style>
  .sidebar-link {
    font-size: 14px;
    color: #6c757d;
    transition: background 0.15s;
  }
  .sidebar-link:hover {
    background: #f8f9fa;
    color: #212529;
  }
  .sidebar-link.active {
    background: #e7f1ff;
    color: #0d6efd;
    font-weight: 500;
    border-left: 3px solid #0d6efd;
  }

  @media (max-width: 991.98px) {
    .sidebar { border-bottom: 1px solid #dee2e6 !important; }
  }
</style>

<%- include('partials/footer') %>