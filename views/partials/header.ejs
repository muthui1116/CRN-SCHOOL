<!DOCTYPE html>
<html lang="en" dir="ltr">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>CRN-Tech</title>
  <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.6.3/css/all.css" integrity="sha384-UHRtZLI+pbxtHCWp1t77Bi1L4ZtiqrqD80Kn4Z8NTSRyMA2Fd33n5dQ8lWUE00s/" crossorigin="anonymous">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
  <link rel="stylesheet" href="/css/styles.css">
</head>

<body>
  <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top shadow-sm">
    <div class="container-fluid px-3 px-md-4 px-lg-5">

      <!-- Brand -->
      <a class="navbar-brand fw-semibold text-dark d-flex align-items-center gap-2" href="/home">
        <span class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-2"
              style="width:34px;height:34px;">
          <i class="fas fa-seedling"></i>
        </span>
        KTN-School
      </a>

    

        <!-- Left links -->
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">

         

        </ul>

        <!-- Right actions -->
        <div class="d-flex align-items-center gap-2 mt-2 mt-lg-0">

     
          <% if (user) { %>
          <!-- User dropdown -->
          <div class="dropdown">
            <button class="btn btn-light border rounded-2 dropdown-toggle d-flex align-items-center gap-2 py-2 px-3"
                    type="button" id="userDropdown"
                    data-bs-toggle="dropdown" aria-expanded="false">
              <span class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle fw-semibold"
                    style="width:26px;height:26px;font-size:11px;">
                <%= user.email.charAt(0).toUpperCase() %>
              </span>
              <span class="d-none d-md-inline text-dark small fw-medium">
                <%= user.email.split('@')[0] %>
              </span>
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 rounded-3 p-2" aria-labelledby="userDropdown">
              <li>
                <a class="dropdown-item rounded-2 py-2 small" href="/profile">
                  <i class="fas fa-user me-2 text-secondary"></i>Profile
                </a>
              </li>
              <% if (user.role === 1) { %>
              <li><hr class="dropdown-divider my-1"></li>
              <li>
                <span class="dropdown-item-text d-flex align-items-center gap-1 small text-warning fw-semibold py-1 px-3">
                  <i class="fas fa-crown"></i> Manager
                </span>
              </li>
              <% } %>
              <li><hr class="dropdown-divider my-1"></li>
              <li>
                <a class="dropdown-item rounded-2 py-2 small text-danger" href="/logout">
                  <i class="fas fa-sign-out-alt me-2"></i>Log out
                </a>
              </li>
            </ul>
          </div>

          <% } else { %>
          <!-- Guest buttons -->
          <a href="/login" class="btn btn-outline-secondary btn-sm rounded-2 px-3">
            <i class="fas fa-sign-in-alt me-1"></i>Log in
          </a>
          <a href="/register" class="btn btn-primary btn-sm rounded-2 px-3">
            <i class="fas fa-user-plus me-1"></i>Sign up
          </a>
          <% } %>

        </div>
      </div>
    </div>
  </nav>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous"></script>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      updateCartCount();
      setInterval(updateCartCount, 5000);
    });

    function updateCartCount() {
      fetch('/cart/count')
        .then(r => r.json())
        .then(data => {
          const badge = document.getElementById('cart-badge');
          if (badge) badge.textContent = data.count || 0;
        })
        .catch(err => console.log('Cart count error:', err));
    }
  </script>

</body>
</html>