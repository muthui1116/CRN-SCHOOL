<%- include('partials/header') %>

<div class="container py-5">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
    <div>
      <h1 class="h3 mb-1">Homework Assignment</h1>
      <p class="text-muted mb-0">
        <% if (homework.subject) { %>
          <strong><%= homework.subject.charAt(0).toUpperCase() + homework.subject.slice(1) %></strong> •
        <% } %>
        Assigned by <strong><%= homework.teacher_name %></strong>
      </p>
    </div>
    <a href="/learner/homework" class="btn btn-outline-secondary btn-sm w-100 w-md-auto">Back to Homework</a>
  </div>

  <div class="row gy-4">
    <!-- Left column: Homework details -->
    <div class="col-12 col-lg-7">
      <div class="card shadow-sm border-0">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="card-title mb-0">Task Details</h5>
            <span class="text-muted small">
              Posted <%= new Date(homework.created_at).toLocaleDateString() %>
            </span>
          </div>

          <div class="mb-4">
            <% if (homework.task_description) { %>
              <div class="p-3 bg-light rounded mb-3">
                <h6 class="fw-semibold mb-2">Instructions:</h6>
                <p class="mb-0"><%= homework.task_description %></p>
              </div>
            <% } %>

            <% if (homework.document_path) { %>
              <div class="p-3 bg-light rounded">
                <h6 class="fw-semibold mb-2">
                  <i class="fas fa-file me-2"></i>Task Document
                </h6>
                <a href="/<%= homework.document_path %>" class="btn btn-sm btn-outline-primary w-100 w-md-auto" download>
                  <i class="fas fa-download me-1"></i>Download PDF/DOCX
                </a>
              </div>
            <% } %>
          </div>

          <hr>

          <% if (homework.submission_id) { %>
            <div class="alert alert-success">
              <i class="fas fa-check-circle me-2"></i>
              <strong>Answer submitted</strong> on <%= new Date(homework.submitted_at).toLocaleDateString() %>
              <% if (homework.teacher_score !== null && homework.teacher_score !== undefined) { %>
                <span class="badge bg-success ms-2"><%= homework.teacher_score %>%</span>
              <% } %>
            </div>

            <div class="p-3 bg-light rounded mb-3">
              <h6 class="fw-semibold mb-2">Your Submission</h6>
              <a href="/<%= homework.answer_document_path %>" class="btn btn-sm btn-outline-secondary w-100 w-md-auto" download>
                <i class="fas fa-file-download me-1"></i>Download Your Answer
              </a>
            </div>

            <% if (homework.teacher_feedback || homework.teacher_score !== null) { %>
              <div class="alert alert-info mt-3">
                <h6 class="fw-semibold mb-2">
                  <i class="fas fa-comment me-1"></i>Teacher Feedback
                </h6>
                <% if (homework.teacher_score !== null) { %>
                  <p class="mb-1"><strong>Score:</strong> <%= homework.teacher_score %>%</p>
                <% } %>
                <% if (homework.teacher_feedback) { %>
                  <p class="mb-0"><%= homework.teacher_feedback %></p>
                <% } %>
                <small class="text-muted mt-2">
                  Feedback received on <%= new Date(homework.feedback_at || homework.submitted_at).toLocaleDateString() %>
                </small>
              </div>
            <% } %>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Right column: Submission form or graded notice -->
    <div class="col-12 col-lg-5">
      <div class="card shadow-sm border-0">
        <div class="card-body">
          <% if (homework.teacher_score !== null && homework.teacher_score !== undefined) { %>
            <div class="alert alert-success mb-4">
              <h5 class="mb-2">Graded Assignment</h5>
              <p class="mb-1">This homework has been graded and resubmission is not allowed.</p>
              <p class="mb-0"><strong>Score:</strong> <%= homework.teacher_score %>%</p>
            </div>
            <div class="mb-4 p-3 bg-light rounded">
              <h6 class="fw-semibold mb-2">Grading Details</h6>
              <% if (homework.teacher_feedback) { %>
                <p class="mb-0"><%= homework.teacher_feedback %></p>
              <% } else { %>
                <p class="mb-0 text-muted">No additional feedback was provided.</p>
              <% } %>
              <small class="text-muted mt-2 d-block">
                Graded on <%= new Date(homework.feedback_at || homework.submitted_at).toLocaleDateString() %>
              </small>
            </div>
          <% } else { %>
            <h5 class="card-title mb-3">
              <% if (homework.submission_id) { %>
                <i class="fas fa-refresh me-2"></i>Resubmit Answer
              <% } else { %>
                <i class="fas fa-upload me-2"></i>Submit Your Answer
              <% } %>
            </h5>

            <form action="/learner/homework/<%= homework.id %>/submit" method="POST" enctype="multipart/form-data">
              <div class="mb-3">
                <label class="form-label fw-semibold">Upload Your Answer <span class="text-danger">*</span></label>
                <div class="input-group">
                  <input type="file" name="answer_document" class="form-control form-control-sm" accept=".pdf,.doc,.docx" required>
                  <span class="input-group-text">
                    <i class="fas fa-file-upload"></i>
                  </span>
                </div>
                <div class="form-text">
                  <i class="fas fa-info-circle me-1"></i>
                  Accepted formats: PDF, DOCX (Microsoft Word). Maximum: 10MB.
                </div>
              </div>

              <button type="submit" class="btn btn-primary w-100">
                <i class="fas fa-check me-2"></i>
                <% if (homework.submission_id) { %>
                  Update Submission
                <% } else { %>
                  Submit Answer
                <% } %>
              </button>
            </form>

            <div class="mt-4 p-3 bg-light rounded">
              <h6 class="fw-semibold mb-2">
                <i class="fas fa-lightbulb me-2"></i>Tips
              </h6>
              <ul class="small mb-0">
                <li>Save your file as PDF or DOCX before uploading</li>
                <li>Make sure your document is clear and readable</li>
                <li>Include your name and class in the document</li>
                <li><% if (homework.submission_id) { %>You can resubmit a new answer<% } else { %>Once submitted, you can update your answer<% } %></li>
              </ul>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
