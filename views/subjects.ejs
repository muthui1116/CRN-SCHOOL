<% title = "Learning Areas"; %>
<div class="row">
  <div class="col-12 col-sm-12">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
          <h3 class="mb-1">Learning Areas</h3>
          <p class="mb-0 text-muted">Manage school learning areas used across exams and student records.</p>
        </div>
        <div class="d-flex gap-2 flex-wrap align-items-center">
          <a href="/subjects" class="btn btn-sm btn-outline-secondary">Refresh</a>
          <a href="/subjects/add" class="btn btn-sm btn-primary">Add Learning Area</a>
        </div>
      </div>
      <div class="card-body">
        <div class="table-responsive rounded-3 shadow-sm">
          <table class="table table-striped table-hover table-sm align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Code</th>
                <th>Description</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (!(subjects||[]).length) { %>
                <tr>
                  <td colspan="5" class="text-center text-muted py-4">No learning areas found. Add one to get started.</td>
                </tr>
              <% } else { %>
                <% (subjects||[]).forEach(subject => { %>
                  <tr>
                    <td><%= subject.id %></td>
                    <td><%= subject.name || 'N/A' %></td>
                    <td><%= subject.code || 'N/A' %></td>
                    <td><%= subject.description || '—' %></td>
                    <td class="table-actions">
                      <div class="d-flex gap-1 flex-wrap">
                        <a href="/subjects/<%= subject.id %>/edit" class="btn btn-sm btn-warning">Edit</a>
                        <form action="/subjects/delete/<%= subject.id %>" method="POST" class="m-0">
                          <button class="btn btn-sm btn-danger" onclick="return confirm('Delete this subject?')">Delete</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
