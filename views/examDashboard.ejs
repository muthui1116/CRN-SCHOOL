<%- include('partials/header') %>

<div class="container-fluid">
  <div class="row g-0">

    <!-- Sidebar (full-width on xs, auto on md+) -->
    <aside class="col-12 col-md-auto bg-white border-bottom border-md-end sidebar p-0">

      <div class="px-3 py-3 border-bottom">
        <h6 class="fw-semibold mb-0 text-dark">School Admin</h6>
        <small class="text-muted">Exam Results</small>
      </div>

      <div class="px-3 pt-3 pb-1">
        <span class="text-uppercase text-muted fw-semibold" style="font-size: 10px; letter-spacing: .08em;">Grades</span>
      </div>

      <% for (let g = 1; g <= 9; g++) { %>
        <a href="/exams?grade=<%= g %>"
           class="d-none d-md-flex align-items-center gap-2 px-3 py-2 text-decoration-none sidebar-link <%= selectedGrade == g ? 'active' : '' %>">
          <i class="fas fa-layer-group fa-sm text-secondary"></i>
          <span>Grade <%= g %></span>
        </a>
      <% } %>

    </aside>

    <!-- Main content -->
    <main class="col bg-light overflow-auto main-content p-3 p-md-4">

      <div class="d-md-none mb-3">
        <form class="row g-2">
          <div class="col-12">
            <label for="gradeSelectMobile" class="form-label small text-muted mb-1">Select Grade</label>
            <select id="gradeSelectMobile" class="form-select form-select-sm" onchange="if(this.value) window.location.href='/exams?grade=' + this.value + '&term=<%= selectedTerm %>'">
              <option value="" <%= !selectedGrade ? 'selected' : '' %>>Choose grade</option>
              <% for (let g = 1; g <= 9; g++) { %>
                <option value="<%= g %>" <%= Number(selectedGrade) === g ? 'selected' : '' %>>Grade <%= g %></option>
              <% } %>
            </select>
          </div>
        </form>
      </div>

      <% if (!selectedGrade) { %>
        <!-- Landing state -->
        <div class="d-flex flex-column align-items-center justify-content-center" style="min-height: 60vh;">
          <i class="fas fa-book-open fa-3x text-muted mb-3"></i>
          <h5 class="text-muted">Select a grade to view exam results</h5>
        </div>

      <% } else { %>

        <!-- Header row -->
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2 mb-4">
          <div>
            <h4 class="mb-0 fw-semibold">Grade <%= selectedGrade %> — Exam Results</h4>
            <small class="text-muted">Term <%= selectedTerm %> • <%= (learners||[]).length %> learner(s)</small>
          </div>
          <div class="exam-btn-group w-100 w-md-auto ms-md-auto">
            <div class="row g-2 align-items-center justify-content-end">
              <div class="col-12 col-sm-6 col-lg-auto">
                <a href="/exams?grade=<%= selectedGrade %>&term=<%= selectedTerm %>" class="btn btn-sm btn-outline-secondary w-100 w-lg-auto">Refresh</a>
              </div>
              <div class="col-12 col-sm-6 col-lg-auto">
                <div class="dropdown">
                  <button class="btn btn-sm btn-outline-secondary dropdown-toggle w-100 w-lg-auto" type="button" id="termDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                    Term <%= selectedTerm %>
                  </button>
                  <ul class="dropdown-menu" aria-labelledby="termDropdown">
                    <li><a class="dropdown-item <%= selectedTerm === '1' ? 'active' : '' %>" href="/exams?grade=<%= selectedGrade %>&term=1">Term 1</a></li>
                    <li><a class="dropdown-item <%= selectedTerm === '2' ? 'active' : '' %>" href="/exams?grade=<%= selectedGrade %>&term=2">Term 2</a></li>
                    <li><a class="dropdown-item <%= selectedTerm === '3' ? 'active' : '' %>" href="/exams?grade=<%= selectedGrade %>&term=3">Term 3</a></li>
                  </ul>
                </div>
              </div>
              <div class="col-12 col-sm-6 col-lg-auto">
                <a href="/exams/add?grade=<%= selectedGrade %>&term=<%= selectedTerm %>" class="btn btn-sm btn-primary w-100 w-lg-auto">Add Result</a>
              </div>
              <div class="col-12 col-sm-6 col-lg-auto">
                <a href="/exams/homework" class="btn btn-sm btn-success w-100 w-lg-auto">
                  <i class="fas fa-book me-1"></i><span class="d-inline d-lg-none">HW</span><span class="d-none d-lg-inline">Homework</span>
                </a>
              </div>
              <div class="col-12 col-sm-6 col-lg-auto">
                <a href="/exams/homework/submissions?grade=<%= selectedGrade %>&term=<%= selectedTerm %>" class="btn btn-sm btn-outline-success w-100 w-lg-auto">
                  <i class="fas fa-clipboard-list me-1"></i><span class="d-none d-md-inline">Grade Subs</span><span class="d-inline d-md-none">Subs</span>
                </a>
              </div>
              <div class="col-12 col-sm-6 col-lg-auto">
                <a href="/exams/export?grade=<%= selectedGrade %>&term=<%= selectedTerm %>" class="btn btn-sm btn-outline-success w-100 w-lg-auto">
                  <i class="fas fa-download me-1"></i>Export
                </a>
              </div>
              <div class="col-12 col-sm-6 col-lg-auto">
                <a href="/exams/bestin?grade=<%= selectedGrade %>&term=<%= selectedTerm %>" class="btn btn-sm btn-outline-primary w-100 w-lg-auto" target="_blank">
                  <i class="fas fa-star me-1"></i>Best In
                </a>
              </div>
              <div class="col-12 col-sm-6 col-lg-auto">
                <a href="/exams/rubric?grade=<%= selectedGrade %>&term=<%= selectedTerm %>" class="btn btn-sm btn-outline-info w-100 w-lg-auto" target="_blank">
                  <i class="fas fa-file-pdf me-1"></i>Rubric
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Submitted homework section (responsive) -->
        <% if (submittedHomework && submittedHomework.length > 0) { %>
        <div class="card border-0 shadow-sm mb-4">
          <div class="card-body">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2 mb-3 <%= selectedTerm === '1' ? 'mb-md-5' : 'mb-md-4' %>">
              <div>
                <h5 class="mb-0">Submitted Homework — Term <%= selectedTerm %></h5>
                <small class="text-muted"><%= submittedHomework.length %> submission(s) for Grade <%= selectedGrade %></small>
              </div>
              <a href="/exams/homework" class="btn btn-sm btn-outline-primary homework-action-btn ms-md-auto">
                <i class="fas fa-book me-1"></i>Go to Homework
              </a>
            </div>

            <div class="table-responsive rounded-2 homework-scroll-container">
              <table class="table table-sm table-striped table-hover table-bordered mb-0 homework-table">
                <thead class="table-dark">
                  <tr>
                    <th style="min-width: 110px;" class="text-start">Learner</th>
                    <th style="min-width: 90px;" class="text-center">Assessment #</th>
                    <th style="min-width: 100px;" class="text-center">Subject</th>
                    <th style="min-width: 95px;" class="text-center">Submitted</th>
                    <th style="min-width: 110px;" class="text-center">Answer</th>
                    <th style="min-width: 80px;" class="text-center">Feedback</th>
                  </tr>
                </thead>
                <tbody>
                  <% submittedHomework.forEach(hw => { %>
                  <tr class="align-middle">
                    <td style="min-width: 110px;" class="text-start"><strong><%= hw.learner_name || 'N/A' %></strong></td>
                    <td style="min-width: 90px;" class="text-center"><span class="badge bg-light text-dark"><%= hw.assessment_number || 'N/A' %></span></td>
                    <td style="min-width: 100px;" class="text-center"><span class="badge bg-info"><%= hw.subject ? hw.subject.replace('_', ' ').replace(/\b\w/g, c => c.toUpperCase()) : 'General' %></span></td>
                    <td style="min-width: 95px;" class="text-center"><small class="text-muted"><%= hw.submitted_at ? new Date(hw.submitted_at).toLocaleDateString() : '—' %></small></td>
                    <td style="min-width: 110px;" class="text-center">
                      <% if (hw.answer_document_path) { %>
                        <a href="/<%= hw.answer_document_path %>" class="btn btn-sm btn-outline-success" download title="Download answer">
                          <i class="fas fa-download me-1"></i><span class="d-none d-sm-inline">Download</span>
                        </a>
                      <% } else { %>
                        <span class="badge bg-secondary">No answer</span>
                      <% } %>
                    </td>
                    <td style="min-width: 80px;" class="text-center">
                      <% if (hw.teacher_feedback) { %>
                        <span class="badge bg-success">Yes</span>
                      <% } else { %>
                        <span class="badge bg-warning text-dark">No</span>
                      <% } %>
                    </td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>

            <!-- Use native horizontal scrollbar on small devices -->
            <!-- Native scrollbar will appear when table overflows horizontally -->
          </div>
        </div>
        <% } %>

      <!-- Results table -->
      <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
          <!-- Scrollable table view for all screens -->
          <div class="table-responsive">
            <table class="table table-striped table-hover mb-0 exam-table">
              <thead class="table-dark">
                <tr>
                  <th class="ps-3">Position</th>
                  <th class="ps-3">Student ID</th>
                  <th>Name</th>
                  <th>Assessment No.</th>
                  <th>Birth Certificate</th>
                  <th>Class Teacher</th>

                  <!-- Subject columns — each has: mark | grade | points -->
                  <% const subjects = subjectDefinitions && subjectDefinitions.length ? subjectDefinitions : [
                    { key: 'english', label: 'English' },
                    { key: 'kiswahili', label: 'Kiswahili' },
                    { key: 'mathematics', label: 'Mathematics' },
                    { key: 'integrated_science', label: 'Int. Science' },
                    { key: 'agriculture', label: 'Agriculture' },
                    { key: 'social_studies', label: 'Social Studies' },
                    { key: 'cre', label: 'CRE' },
                    { key: 'pre_technical', label: 'Pre-Technical' },
                    { key: 'creative_arts', label: 'Creative Arts' }
                  ]; %>
                  <% subjects.forEach(subject => { %>
                    <th colspan="3" class="text-center border-start subject-header"><%= subject.label %></th>
                  <% }) %>
                  <th colspan="3" class="text-center border-start subject-header">EVRG</th>

                  <th class="text-center border-start">Actions</th>
                </tr>
                <!-- Sub-header row -->
                <tr class="table-secondary sub-header">
                  <th colspan="6"></th>
                  <% subjects.forEach(() => { %>
                    <th class="text-center border-start sub-col">MRK</th>
                    <th class="text-center sub-col">PL</th>
                    <th class="text-center sub-col">PTS</th>
                  <% }) %>
                  <th class="text-center border-start sub-col">MRK</th>
                  <th class="text-center sub-col">PL</th>
                  <th class="text-center sub-col">PTS</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% (learners||[]).forEach((l, i) => { %>
                <tr>
                  <td class="ps-3 text-muted"><%= l.pos || '—' %></td>
                  <td class="ps-3 text-muted"><%= l.learner_id || l.id || 'N/A' %></td>
                  <td class="fw-medium"><%= l.name || 'N/A' %></td>
                  <td><%= l.assessment_number || 'N/A' %></td>
                  <td><%= l.birth_certificate || 'N/A' %></td>
                  <td><%= l.class_teacher || 'N/A' %></td>

                  <% subjects.forEach(subject => {
                    const code = subject.key;
                    const subjectRow = l.subjectRows && l.subjectRows[code];
                    const mark = subjectRow?.mark ?? l[code] ?? '—';
                    const pl = subjectRow?.pl ?? l[`${code}_pl`] ?? '—';
                    const points = subjectRow?.points ?? l[`${code}_points`] ?? '—';
                  %>
                    <td class="text-center border-start"><%= mark !== null && mark !== undefined && mark !== '' ? mark : '—' %></td>
                    <td class="text-center"><span class="grade-badge"><%= pl || '—' %></span></td>
                    <td class="text-center"><%= points || '—' %></td>
                  <% }) %>

                  <!-- EVRG -->
                  <td class="text-center border-start"><%= l.evrg || '—' %></td>
                  <td class="text-center"><span class="grade-badge"><%= l.evrg_pl || '—' %></span></td>
                  <td class="text-center"><%= l.evrg_points || '—' %></td>

                  <!-- Actions -->
                    <td class="text-center border-start">
                      <div class="d-flex gap-2 flex-nowrap justify-content-center align-items-center">
                        <a href="/exams/<%= l.result_id %>/edit?grade=<%= selectedGrade %>&term=<%= selectedTerm %>" class="btn btn-sm btn-warning">Edit</a>
                        <form action="/exams/delete/<%= l.result_id %>" method="POST" style="display:inline;">
                          <input type="hidden" name="grade" value="<%= selectedGrade %>">
                          <input type="hidden" name="term" value="<%= selectedTerm %>">
                          <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this result?')">Del</button>
                        </form>
                      </div>
                    </td>
                </tr>
                <% }) %>

                <% if ((learners||[]).length === 0) { %>
                <tr>
                  <td colspan="37" class="text-center text-muted py-5">
                    <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                    No results found for Grade <%= selectedGrade %>.
                    <a href="/exams/add?grade=<%= selectedGrade %>&term=<%= selectedTerm %>">Add the first one.</a>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

    <% } %>
  </div>
</div>

<style>
  .sidebar {
    flex: 0 0 auto;
    width: auto;
    min-width: 180px;
    max-width: 320px;
  }

  .main-content {
    min-width: 0;
  }

  .sidebar-link {
    font-size: 14px;
    color: #6c757d;
    transition: background 0.15s;
    white-space: nowrap;
  }
  .sidebar-link:hover {
    background: #f8f9fa;
    color: #212529;
  }
  .sidebar-link.active {
    background: #e7f1ff;
    color: #0d6efd;
    font-weight: 500;
    border-left: 3px solid #0d6efd;
  }

  .exam-btn-group .btn {
    min-height: 38px;
  }

  @media (max-width: 991.98px) {
    .sidebar {
      width: 100%;
      max-width: 100%;
      border-bottom: 1px solid #dee2e6 !important;
    }
    .sidebar-link {
      padding: 0.75rem 0.5rem !important;
    }
  }

  @media (max-width: 767.98px) {
    .main-content {
      padding: 1rem !important;
    }
    .exam-btn-group .btn {
      width: 100% !important;
    }
    .exam-table {
      font-size: 12px;
    }
    .exam-table thead th,
    .exam-table td {
      white-space: nowrap;
    }
    .exam-table {
      min-width: 1300px;
    }
    .exam-table td,
    .exam-table th {
      padding: 0.55rem 0.65rem;
    }
    .badge {
      font-size: 0.825rem;
    }
    #gradeSelectMobile {
      width: 100%;
    }
  }

  .exam-table {
    font-size: 13px;
  }
  .exam-table thead th {
    white-space: nowrap;
    font-size: 12px;
  }
  .subject-header {
    background-color: #1a1d23 !important;
    letter-spacing: 0.04em;
  }
  .sub-header th {
    font-size: 11px;
    color: #6c757d;
    font-weight: 500;
  }
  .sub-col {
    min-width: 42px;
  }
  .grade-badge {
    display: inline-block;
    padding: 1px 6px;
    border-radius: 4px;
    background: #e9ecef;
    font-size: 11px;
    font-weight: 600;
    color: #495057;
  }

  /* Homework table responsive scrolling */
  .table-responsive {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    overflow-y: visible;
  }
  
  .table-responsive.rounded-2 {
    border-radius: 0.25rem;
  }

  /* Ensure homework scroll container can show native scrollbar */
  .table-responsive.rounded-2.homework-scroll-container {
    overflow-x: auto;
    overflow-y: visible;
  }

  .homework-table {
    font-size: 13px;
  }

  .homework-table thead th {
    white-space: nowrap;
    font-weight: 600;
    background-color: #212529;
    color: white;
    border-bottom: 2px solid #dee2e6;
    padding: 0.65rem 0.5rem;
  }

  .homework-table tbody td {
    vertical-align: middle;
    padding: 0.6rem 0.5rem;
    border-color: #e9ecef;
  }

  .homework-table tbody tr {
    transition: background-color 0.2s ease;
  }

  .homework-table tbody tr:hover {
    background-color: #f8f9fa;
  }

  .homework-table .badge {
    font-size: 10px;
    padding: 0.4rem 0.6rem;
    font-weight: 500;
  }

  .homework-table .btn-sm {
    padding: 0.4rem 0.6rem;
    font-size: 11px;
    white-space: nowrap;
  }

  .homework-table .btn-outline-success {
    border-color: #198754;
    color: #198754;
  }

  .homework-table .btn-outline-success:hover {
    background-color: #198754;
    border-color: #198754;
    color: white;
  }
  /* Use native horizontal scrollbar for homework list on overflow */
  .homework-scroll-container {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  /* Ensure table becomes wider than container to trigger horizontal scroll on small devices */
  .homework-table {
    min-width: 720px;
  }

  /* Lightweight cross-browser scrollbar styling */
  .homework-scroll-container::-webkit-scrollbar {
    height: 10px;
  }
  .homework-scroll-container::-webkit-scrollbar-track {
    background: transparent;
  }
  .homework-scroll-container::-webkit-scrollbar-thumb {
    background: rgba(0,0,0,0.18);
    border-radius: 8px;
  }
  .homework-scroll-container {
    scrollbar-width: thin;
    scrollbar-color: rgba(0,0,0,0.18) transparent;
  }

  @media (max-width: 768px) {
    .table-responsive {
      margin-bottom: 1rem;
    }
    .table-responsive > .table {
      margin-bottom: 0;
    }
    .homework-table {
      font-size: 11px;
    }
    .homework-table thead th {
      padding: 0.45rem 0.3rem;
      font-size: 9px;
    }
    .homework-table tbody td {
      padding: 0.35rem 0.3rem;
      white-space: nowrap;
    }
    .homework-table th,
    .homework-table td {
      min-width: auto !important;
    }
    .homework-table .badge {
      font-size: 8px;
      padding: 0.3rem 0.4rem;
    }
    .btn-sm {
      padding: 0.25rem 0.4rem;
      font-size: 8px;
    }
    .btn-sm .fa {
      font-size: 8px;
      margin-right: 2px !important;
    }
  }

  .homework-action-btn {
    min-width: auto;
    font-weight: 600;
    letter-spacing: 0.01em;
    border-width: 1.5px;
    padding: 0.45rem 0.85rem;
  }
  .homework-action-btn:hover {
    background: #0d6efd;
    color: #fff;
  }
  @media (min-width: 768px) {
    .homework-action-btn {
      min-width: 150px;
      padding: 0.55rem 0.95rem;
      font-size: 0.85rem;
    }
  }
</style>

<script>
  function computeGrade(mark) {
    const m = Number(mark);
    if (mark === '' || isNaN(m)) return { pl: '—', pts: '—', cls: '' };
    if (m < 25)  return { pl: 'BE', pts: '1', cls: 'danger' };
    if (m < 50)  return { pl: 'AE', pts: '2', cls: 'warning' };
    if (m < 75)  return { pl: 'ME', pts: '3', cls: 'info' };
    return       { pl: 'EE', pts: '4', cls: 'success' };
  }

  document.querySelectorAll('input[type="number"]').forEach(input => {
    // Find or create the badge next to each input
    const badge = document.createElement('small');
    badge.className = 'ms-2 badge bg-secondary';
    input.closest('.mb-3').querySelector('label').after(badge);

    input.addEventListener('input', () => {
      const { pl, pts, cls } = computeGrade(input.value);
      badge.textContent = pl !== '—' ? `${pl} · ${pts} pt` : '';
      badge.className = `ms-2 badge bg-${cls || 'secondary'}`;
    });
  });

  // Native horizontal scrolling is used for the homework list on overflow.
  // Custom JS scrollbar removed to rely on the browser's default behavior.
</script>

<%- include('partials/footer') %>


