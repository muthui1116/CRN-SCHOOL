<%- include('partials/header') %>

<div class="container py-5">
  <div class="card shadow-sm border-0">
    <div class="card-body">
      <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
        <div>
          <h3 class="mb-1">Add Exam Result</h3>
          <p class="text-muted mb-0">Grade <strong><%= grade %></strong> • Term <strong><%= selectedTerm %></strong></p>
        </div>
        <a href="/exams?grade=<%= grade %>&term=<%= selectedTerm %>" class="btn btn-outline-secondary btn-sm w-100 w-md-auto">Back to results</a>
      </div>

      <form action="/exams/add" method="POST">
        <input type="hidden" name="grade" value="<%= grade %>">
        <input type="hidden" name="term" value="<%= selectedTerm %>">

        <div class="row gx-3 mb-4">
          <div class="col-12 col-lg-6">
            <label class="form-label fw-semibold">Grade</label>
            <select id="gradeSelect" class="form-select form-select-sm" required>
              <% for (let i = 1; i <= 9; i++) { %>
                <option value="<%= i %>" <%= String(grade || 1) === String(i) ? 'selected' : '' %>>Grade <%= i %></option>
              <% } %>
            </select>
            <div class="form-text">Choose the grade and manage the subjects for this result sheet.</div>
          </div>
          <div class="col-12 col-lg-6">
            <label class="form-label fw-semibold">Learner</label>
            <select name="learner_id" class="form-select form-select-sm" required>
              <option value="">Select learner</option>
              <% if ((learners||[]).length === 0) { %>
                <option value="" disabled>No learners found for this grade.</option>
              <% } else { %>
                <% learners.forEach(l => { %>
                  <option value="<%= l.id %>" <%= selectedLearnerId && String(selectedLearnerId) === String(l.id) ? 'selected' : '' %>><%= l.name %> (<%= l.assessment_number || 'No assessment #' %>)</option>
                <% }) %>
              <% } %>
            </select>
            <div class="form-text">Choose the learner whose term result you want to record.</div>
          </div>
        </div>

        <div class="row mb-4">
          <div class="col-12 col-lg-8">
            <label class="form-label fw-semibold">Subjects</label>
            <div class="d-flex flex-wrap gap-2 mb-3" id="subjectButtonList"></div>
            <div class="input-group input-group-sm">
              <select id="subjectSelect" class="form-select form-select-sm">
                <option value="">Add a subject</option>
              </select>
              <button type="button" id="addSubjectBtn" class="btn btn-outline-primary">Add</button>
            </div>
            <div class="form-text">Click a subject pill to remove it, or use the dropdown to add a subject back.</div>
          </div>
        </div>

        <div id="selectedSubjectInputs"></div>

        <div class="table-responsive shadow-sm rounded overflow-auto">
          <table class="table table-bordered mb-0 align-middle">
            <thead class="table-secondary">
              <tr>
                <th class="fw-semibold">Subject</th>
                <th class="text-center fw-semibold">CAT1</th>
                <th class="text-center fw-semibold">CAT2</th>
                <th class="text-center fw-semibold">Main</th>
                <th class="text-center fw-semibold">Final</th>
              </tr>
            </thead>
            <tbody>
              <% const examSubjects = subjectDefinitions && subjectDefinitions.length ? subjectDefinitions : [
                { key: 'english', label: 'English' },
                { key: 'kiswahili', label: 'Kiswahili' },
                { key: 'mathematics', label: 'Mathematics' },
                { key: 'integrated_science', label: 'Integrated Science' },
                { key: 'agriculture', label: 'Agriculture' },
                { key: 'social_studies', label: 'Social Studies' },
                { key: 'cre', label: 'CRE' },
                { key: 'pre_technical', label: 'Pre-Technical' },
                { key: 'creative_arts', label: 'Creative Arts' }
              ]; %>
              <% examSubjects.forEach(subject => { %>
                <tr class="subject-row" data-subject="<%= subject.key %>">
                  <td class="fw-semibold">
                    <span><%= subject.label %></span>
                  </td>
                  <td class="text-center"><input type="number" name="<%= subject.key %>_cat1" class="form-control form-control-sm occasion-input text-center" min="0" max="100" step="1"></td>
                  <td class="text-center"><input type="number" name="<%= subject.key %>_cat2" class="form-control form-control-sm occasion-input text-center" min="0" max="100" step="1"></td>
                  <td class="text-center"><input type="number" name="<%= subject.key %>_main" class="form-control form-control-sm occasion-input text-center" min="0" max="100" step="1"></td>
                  <td class="text-center"><input type="text" class="form-control form-control-sm final-mark text-center" data-subject="<%= subject.key %>" readonly></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <div class="row align-items-center mt-4">
          <div class="col-12 col-md-8">
            <div class="alert alert-info mb-0">
              <strong>Score formula:</strong> CAT1/100×15 + CAT2/100×15 + Main Exam/100×70. Final marks appear live as you type.
            </div>
          </div>
          <div class="col-12 col-md-4 text-md-end mt-3 mt-md-0">
            <button type="submit" class="btn btn-primary px-4 w-100 w-md-auto">Save Result</button>
          </div>
        </div>
      </form>

      <% const examSubjectsData = subjectDefinitions && subjectDefinitions.length ? subjectDefinitions : [
          { key: 'english', label: 'English' },
          { key: 'kiswahili', label: 'Kiswahili' },
          { key: 'mathematics', label: 'Mathematics' },
          { key: 'integrated_science', label: 'Integrated Science' },
          { key: 'agriculture', label: 'Agriculture' },
          { key: 'social_studies', label: 'Social Studies' },
          { key: 'cre', label: 'CRE' },
          { key: 'pre_technical', label: 'Pre-Technical' },
          { key: 'creative_arts', label: 'Creative Arts' }
        ]; %>
      <script>
        const learnersData = <%- JSON.stringify(learners || []) %>;
        const examSubjects = <%- JSON.stringify(examSubjectsData) %>;
        const gradeValue = "<%= grade || '' %>";
        const selectedTermValue = "<%= selectedTerm %>";
        const learnerSelect = document.querySelector('[name="learner_id"]');
        const gradeSelect = document.getElementById('gradeSelect');
        const gradeInput = document.querySelector('input[name="grade"]');
        const subjectSelect = document.getElementById('subjectSelect');
        const addSubjectBtn = document.getElementById('addSubjectBtn');
        const selectedSubjectInputs = document.getElementById('selectedSubjectInputs');

        const subjectKeys = () => examSubjects.map(subject => subject.key);

        const setRowState = (row, enabled) => {
          row.hidden = !enabled;
          row.querySelectorAll('input').forEach(input => {
            input.disabled = !enabled;
            if (!enabled) input.value = '';
          });
        };

        const subjectButtonList = document.getElementById('subjectButtonList');

        const syncSelectedSubjectInputs = activeKeys => {
          if (!selectedSubjectInputs) return;
          selectedSubjectInputs.innerHTML = activeKeys.map(key => `<input type="hidden" name="selected_subjects[]" value="${key}">`).join('');
        };

        const activeSubjectKeys = () => Array.from(document.querySelectorAll('.subject-row:not([hidden])')).map(row => row.dataset.subject);

        const renderSubjectButtons = () => {
          if (!subjectButtonList) return;
          const activeKeys = activeSubjectKeys();
          subjectButtonList.innerHTML = activeKeys.map(key => {
            const subject = examSubjects.find(subject => subject.key === key);
            const label = subject ? subject.label : key;
            return `
              <button type="button" class="btn btn-sm btn-outline-danger subject-pill" data-subject="${key}">
                ${label} <span aria-hidden="true">&times;</span>
              </button>
            `;
          }).join('');
          document.querySelectorAll('.subject-pill').forEach(button => {
            button.addEventListener('click', () => removeSubjectRow(button.dataset.subject));
          });
        };

        const updateSubjectOptions = () => {
          if (!subjectSelect) return;
          const selectedValue = subjectSelect.value;
          const hiddenSubjects = examSubjects.filter(subject => {
            const row = document.querySelector(`.subject-row[data-subject="${subject.key}"]`);
            return row && row.hidden;
          });

          subjectSelect.innerHTML = '<option value="">Add a subject</option>';
          hiddenSubjects.forEach(subject => {
            const option = document.createElement('option');
            option.value = subject.key;
            option.textContent = subject.label;
            if (subject.key === selectedValue) {
              option.selected = true;
            }
            subjectSelect.appendChild(option);
          });

          if (selectedValue && !hiddenSubjects.some(subject => subject.key === selectedValue)) {
            subjectSelect.value = '';
          }
          addSubjectBtn.disabled = hiddenSubjects.length === 0 || !subjectSelect.value;
        };

        const updateSubjectState = (shouldSave = true) => {
          syncSelectedSubjectInputs(activeSubjectKeys());
          updateSubjectOptions();
          renderSubjectButtons();
          if (shouldSave) saveFormState();
        };

        const initializeSubjectRows = () => {
          examSubjects.forEach(subject => {
            const row = document.querySelector(`.subject-row[data-subject="${subject.key}"]`);
            if (!row) return;
            setRowState(row, false);
          });
          updateSubjectState(false);
        };

        const removeSubjectRow = key => {
          const row = document.querySelector(`.subject-row[data-subject="${key}"]`);
          if (!row) return;
          setRowState(row, false);
          updateFinal();
          updateSubjectState();
        };

        const addSubjectRow = key => {
          const row = document.querySelector(`.subject-row[data-subject="${key}"]`);
          if (!row) return;
          setRowState(row, true);
          updateSubjectState();
        };

        const parseScore = value => {
          if (value === '' || value === null || value === undefined) return null;
          const n = Number(value);
          return Number.isFinite(n) ? n : null;
        };

        const clampMarkInput = input => {
          if (!input) return;
          const value = input.value;
          if (value === '' || value === null || value === undefined) return;
          const n = Number(value);
          if (!Number.isFinite(n)) {
            input.value = '';
            return;
          }
          if (n < 0) {
            input.value = '0';
          } else if (n > 100) {
            input.value = '100';
          }
        };

        const getFinalMark = (cat1, cat2, main) => {
          if (cat1 === null && cat2 === null && main === null) return null;
          const scoreCat1 = cat1 || 0;
          const scoreCat2 = cat2 || 0;
          const scoreMain = main || 0;
          return Math.round((scoreCat1 / 100 * 15) + (scoreCat2 / 100 * 15) + (scoreMain / 100 * 70));
        };

        const getStateKey = (learnerId = null) => {
          const id = learnerId !== null ? learnerId : (learnerSelect ? learnerSelect.value || 'none' : 'none');
          return `exam_add_${gradeValue}_${selectedTermValue}_${id}`;
        };

        const saveFormState = () => {
          const state = {
            learner_id: learnerSelect ? learnerSelect.value : null,
            activeSubjects: activeSubjectKeys(),
            values: {}
          };
          subjectKeys().forEach(subject => {
            state.values[`${subject}_cat1`] = document.querySelector(`input[name="${subject}_cat1"]`)?.value || '';
            state.values[`${subject}_cat2`] = document.querySelector(`input[name="${subject}_cat2"]`)?.value || '';
            state.values[`${subject}_main`] = document.querySelector(`input[name="${subject}_main"]`)?.value || '';
          });
          localStorage.setItem(getStateKey(), JSON.stringify(state));
        };

        const findSavedState = () => {
          const exact = localStorage.getItem(getStateKey());
          if (exact) return exact;
          const prefix = `exam_add_${gradeValue}_${selectedTermValue}_`;
          for (let i = 0; i < localStorage.length; i++) {
            const key = localStorage.key(i);
            if (typeof key === 'string' && key.startsWith(prefix)) {
              return localStorage.getItem(key);
            }
          }
          return null;
        };

        const loadFormState = () => {
          const saved = findSavedState();
          if (!saved) return false;
          try {
            const state = JSON.parse(saved);
            if (learnerSelect && state.learner_id && learnerSelect.querySelector(`option[value="${state.learner_id}"]`)) {
              learnerSelect.value = state.learner_id;
            }
            const activeSubjects = Array.isArray(state.activeSubjects)
              ? state.activeSubjects
              : subjectKeys().filter(subject => {
                  return (state.values && (
                    state.values[`${subject}_cat1`] ||
                    state.values[`${subject}_cat2`] ||
                    state.values[`${subject}_main`]
                  ));
                });
            subjectKeys().forEach(subject => {
              const row = document.querySelector(`.subject-row[data-subject="${subject}"]`);
              const cat1 = document.querySelector(`input[name="${subject}_cat1"]`);
              const cat2 = document.querySelector(`input[name="${subject}_cat2"]`);
              const main = document.querySelector(`input[name="${subject}_main"]`);
              if (!cat1 || !cat2 || !main || !row) return;
              const isActive = activeSubjects.includes(subject);
              setRowState(row, isActive);
              cat1.value = (state.values && state.values[`${subject}_cat1`]) || '';
              cat2.value = (state.values && state.values[`${subject}_cat2`]) || '';
              main.value = (state.values && state.values[`${subject}_main`]) || '';
            });
            updateFinal();
            updateSubjectState();
            return true;
          } catch (err) {
            console.error('Failed to restore form state', err);
            return false;
          }
        };

        const updateFinal = () => {
          subjectKeys().forEach(subject => {
            const cat1 = document.querySelector(`input[name="${subject}_cat1"]`);
            const cat2 = document.querySelector(`input[name="${subject}_cat2"]`);
            const main = document.querySelector(`input[name="${subject}_main"]`);
            const finalField = document.querySelector(`.final-mark[data-subject="${subject}"]`);
            if (!cat1 || !cat2 || !main || !finalField) return;
            const finalMark = getFinalMark(parseScore(cat1.value), parseScore(cat2.value), parseScore(main.value));
            finalField.value = finalMark === null ? '' : finalMark;
          });
        };

        const populateLearnerScores = learnerId => {
          const learner = learnersData.find(l => String(l.id) === String(learnerId) || String(l.learner_id) === String(learnerId));
          subjectKeys().forEach(subject => {
            const row = document.querySelector(`.subject-row[data-subject="${subject}"]`);
            const cat1 = document.querySelector(`input[name="${subject}_cat1"]`);
            const cat2 = document.querySelector(`input[name="${subject}_cat2"]`);
            const main = document.querySelector(`input[name="${subject}_main"]`);
            if (!cat1 || !cat2 || !main || !row) return;
            if (learner) {
              const saved = learner.subjectRows && learner.subjectRows[subject];
              if (saved) {
                cat1.value = saved.cat1 ?? '';
                cat2.value = saved.cat2 ?? '';
                main.value = saved.main ?? '';
              } else {
                cat1.value = learner[`${subject}_cat1`] ?? '';
                cat2.value = learner[`${subject}_cat2`] ?? '';
                main.value = learner[`${subject}_main`] ?? '';
              }
              if (cat1.value || cat2.value || main.value) {
                setRowState(row, true);
              }
            } else {
              cat1.value = '';
              cat2.value = '';
              main.value = '';
            }
          });
          updateFinal();
          updateSubjectState();
          saveFormState();
        };

        const changeGrade = () => {
          const selectedGrade = gradeSelect?.value || gradeValue || '1';
          if (gradeInput) {
            gradeInput.value = selectedGrade;
          }
          const params = new URLSearchParams(window.location.search);
          params.set('grade', selectedGrade);
          params.set('term', selectedTermValue);
          window.location.href = `${window.location.pathname}?${params.toString()}`;
        };

        if (learnerSelect) {
          learnerSelect.addEventListener('change', event => {
            populateLearnerScores(event.target.value);
          });
        }

        gradeSelect?.addEventListener('change', changeGrade);
        subjectSelect?.addEventListener('change', updateSubjectOptions);

        addSubjectBtn?.addEventListener('click', () => {
          const subjectKey = subjectSelect?.value;
          if (!subjectKey) return;
          addSubjectRow(subjectKey);
          if (subjectSelect) subjectSelect.value = '';
          updateSubjectOptions();
        });

        document.querySelectorAll('.remove-subject-btn').forEach(button => {
          button.addEventListener('click', () => removeSubjectRow(button.dataset.subject));
        });

        initializeSubjectRows();

        document.addEventListener('input', event => {
          if (!event.target.matches('.occasion-input')) return;
          clampMarkInput(event.target);
          updateFinal();
          saveFormState();
        });

        const restored = loadFormState();
        if (!restored && learnerSelect) {
          if (learnerSelect.value) {
            populateLearnerScores(learnerSelect.value);
          } else if (window.location.search.includes('learner_id=')) {
            const params = new URLSearchParams(window.location.search);
            const learnerId = params.get('learner_id');
            if (learnerId) {
              learnerSelect.value = learnerId;
              populateLearnerScores(learnerId);
            }
          }
        }

        const form = document.querySelector('form');
        if (form) {
          form.addEventListener('submit', () => {
            if (gradeSelect) {
              gradeInput.value = gradeSelect.value;
            }
            saveFormState();
          });
        }
      </script>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

