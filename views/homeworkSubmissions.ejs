<%- include('partials/header') %>

<div class="container py-5">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
    <div>
      <h1 class="h3 mb-1">Homework Submissions</h1>
      <p class="text-muted mb-0">Review learner answers and assign scores.</p>
    </div>
    <a href="/exams" class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center gap-2 shadow-sm">
      <i class="fas fa-arrow-left"></i>
      Back to Exams
    </a>
  </div>

  <div class="card shadow-sm border-0">
    <div class="card-body">
      <% if (!submissions || submissions.length === 0) { %>
        <div class="alert alert-info mb-0">
          <i class="fas fa-info-circle me-2"></i>No homework submissions found.
        </div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table table-sm table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Learner</th>
                <th>Grade</th>
                <th>Learning Area</th>
                <th>Submitted</th>
                <th>Score</th>
                <th>Feedback</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% submissions.forEach(submission => { %>
                <tr>
                  <td><%= submission.learner_name %></td>
                  <td><%= submission.homework_grade %></td>
                  <td><%= submission.subject_name || 'General' %></td>
                  <td><%= submission.submitted_at ? new Date(submission.submitted_at).toLocaleDateString() : '—' %></td>
                  <td><%= submission.teacher_score !== null ? submission.teacher_score + '%' : 'Not graded' %></td>
                  <td><%= submission.teacher_feedback ? 'Yes' : 'No' %></td>
                  <td>
                    <a href="/exams/homework/submissions/<%= submission.submission_id %>/edit" class="btn btn-sm btn-primary w-100 w-md-auto">
                      Grade
                    </a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
